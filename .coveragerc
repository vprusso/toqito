# .coveragerc to control coverage.py
[run]
source = toqito
branch = True

[report]
show_missing = True
precision = 2
# Fail the coverage run if total coverage drops below this floor. Adjust upward toward the codecov target (70..90)
# as coverage allows.
fail_under = 80
omit =
    */__init__.py
    */tests/*
    */virtualenvs/*
    */.tox/*
    */venv/*
    */.venv/*

[html]
directory = coverage_html_report

